{
  "name": "enhanced-resolve",
  "version": "5.20.0",
  "description": "Offers a async require.resolve function. It's highly configurable.",
  "homepage": "http://github.com/webpack/enhanced-resolve",
  "repository": {
    "type": "git",
    "url": "git://github.com/webpack/enhanced-resolve.git"
  },
  "license": "MIT",
