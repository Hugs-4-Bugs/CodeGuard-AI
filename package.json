{
  "name": "codeguard-ai",
  "publisher": "codeguard",
  "displayName": "CodeGuard AI",
  "description": "AWS cost verification for AI-generated infrastructure",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:terraform",
    "workspaceContains:**/*.tf",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeguard.analyze",
        "title": "CodeGuard: Analyze Current File"
      }
    ],
    "languages": [
      {
        "id": "terraform",
        "extensions": [
          ".tf",
          ".tfvars"
        ],
        "aliases": [
          "Terraform",
          "terraform"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  }
}
